{
  "permissions": {
    "allow": [
      "Bash(python -m http.server 8080)",
      "Bash(Start-Sleep -Seconds 2)",
      "Bash(curl -s -o /dev/null -w \"%{http_code}\" http://localhost:8080/index.html)",
      "Bash(npx --version)",
      "Bash(npx --yes serve -l 8080 .)",
      "Bash(curl -s -o /dev/null -w \"%{http_code}\" http://localhost:8080/)",
      "Bash(curl -sL -o /dev/null -w \"%{http_code}\" http://localhost:8080/index.html)",
      "Bash(git init *)",
      "Bash(git add *)",
      "Bash(git config *)",
      "Bash(git remote *)",
      "Bash(git branch *)",
      "Bash(git push *)",
      "Bash(powershell -Command ' *)",
      "Bash(git commit -m ' *)"
    ]
  }
}
